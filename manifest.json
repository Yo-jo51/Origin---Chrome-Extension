{
  "manifest_version": 3,
  "name": "Origin - Minimal New Tab",
  "version": "1.1",
  "author": "Jan",
  "description": "A simple and very Minimal New Tab extension.",
  "permissions": 
  [
    "geolocation",
    "favicon",
    "storage"
  ],

  "chrome_url_overrides": {
    "newtab": "tabs/newtab.html"
  },
  "options_ui": {
    "page": "options/settings.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "resources/audio/ButtonPres.wav",
        "_favicon/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "resources/images/icon.png",
    "48": "resources/images/icon.png",
    "128": "resources/images/icon.png"
  }
}
